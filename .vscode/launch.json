{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "AVR simulavr Debug",
      "type": "gdb",
      "request": "attach",
      "executable": "/home/notnatedavis/Desktop/everything/coding/school/SER486-Spring26B/Module 2/Homework 2/bin/homework2.elf",
      "target": ":1234",
      "remote": true,
      "cwd": "${workspaceFolder}",
      "gdbpath": "avr-gdb",
      "autorun": [
        "display *(unsigned char*)0x24",
        "display *(unsigned char*)0x25"
      ]
    },
    {
      "name": "(gdb) Pipe Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "enter program name, for example ${workspaceFolder}/a.out",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false,
      "pipeTransport": {
        "debuggerPath": "/usr/bin/gdb",
        "pipeProgram": "/usr/bin/ssh",
        "pipeArgs": [],
        "pipeCwd": ""
      },
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
